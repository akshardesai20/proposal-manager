# Copy to .env for local dev. On Render, these are set as environment
# variables directly (DATABASE_URL is auto-populated if you use the
# render.yaml blueprint).
DATABASE_URL=postgres://user:password@localhost:5432/proposalflow_demo
JWT_SECRET=change-this-to-a-long-random-string
PORT=4000

# Company branding — shown on the offer PDF letterhead/cover letter and,
# via the frontend's VITE_COMPANY_NAME, in the app UI.
COMPANY_NAME=Your Company Name
COMPANY_ADDRESS_LINES=Address Line 1|Address Line 2|City - PIN
COMPANY_PHONE=+91 00000 00000
COMPANY_EMAIL=sales@example.com
COMPANY_MANUFACTURER=Siemens
COMPANY_ESTABLISHED_YEAR=2000
COMPANY_PRODUCT_RANGE=Differential Pressure Transmitters|Pressure Transmitters|Level Transmitters

# Protects POST /api/internal/seed-demo-data — any random string.
DEMO_SEED_SECRET=change-this-too

# Optional: auto-seed a real admin user on first boot (see src/seedAdmin.js).
# Leave unset for the demo instance — the seed-demo-data endpoint creates
# its own admin@demo.local account instead.
# ADMIN_EMAIL=
# ADMIN_NAME=
# ADMIN_PASSWORD=

# Optional: email-inbox polling (see src/mail/pollInbox.js). Leave unset if
# this deployment doesn't need inbound-email capture.
# INBOX_IMAP_HOST=
# INBOX_IMAP_PORT=993
# INBOX_IMAP_USER=
# INBOX_IMAP_PASSWORD=
# INBOX_POLL_SECRET=
